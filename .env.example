# BUILD UP PILOT Environment Configuration
# Copy this file to .env and update with your actual values

# Database Configuration
DATABASE_URL=sqlite:///buildup.db
REDIS_URL=redis://localhost:6379

# SMS Gateway Configuration (for real OTP delivery)
SMS_GATEWAY_URL=https://api.twilio.com/2010-04-01/Accounts
SMS_API_KEY=your_twilio_api_key_here
SMS_FROM_NUMBER=+1234567890

# Aadhaar KYC Provider Configuration
AADHAAR_API_BASE_URL=https://api.kycprovider.com
AADHAAR_API_KEY=your_aadhaar_api_key_here

# Application Configuration
SECRET_KEY=your-secret-key-here
DEMO_MODE=false

# Session Configuration
SESSION_TYPE=redis
SESSION_PERMANENT=false
SESSION_USE_SIGNER=true
PERMANENT_SESSION_LIFETIME=3600
